# noCluNetwork environment configuration.
# Copy this file to .env and fill in the values. Never commit .env.

# Runtime
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info

# CORS: "*" allows all origins, or pass a comma-separated list of origins.
CORS_ORIGIN=*

# PostgreSQL.
# Local dev (docker-compose.dev.yml) maps Postgres to host port 5439.
# A production DATABASE_URL against DigitalOcean managed Postgres must end with
# &uselibpqcompat=true, or node-pg attempts sslmode=verify-full and fails on the
# self-signed cert with SELF_SIGNED_CERT_IN_CHAIN. psql does not need the suffix.
DATABASE_URL=postgres://noclu:noclu@localhost:5439/noclunetwork

# Redis. The single ncn: keyspace prefix is applied in code, not here.
REDIS_URL=redis://localhost:6379

# Service token: bots authenticate to this API with X-Service-Token plus
# X-Service-Name. Generate a long random value for production.
SERVICE_TOKEN=change-me-in-production

# noclulabs.com channel (the bridge to noCluID). The separate trusted credential
# noCluNetwork uses to call noclulabs.com for the intake (signal write), the
# scoped read (noCluID data), and the verify-sync read (surface B). Optional until
# the verify-sync poller is enabled (see VERIFY_SYNC_ENABLED below), which requires
# both. In production NOCLULABS_BASE_URL points at the private VPC address.
NOCLULABS_BASE_URL=
NOCLULABS_SERVICE_TOKEN=
# The outbound request timeout for every call to noclulabs.com, in milliseconds.
NOCLULABS_HTTP_TIMEOUT_MS=10000

# Verify-sync poller (the inbound bridge verify capability). A background poller
# reads verified Discord connections from noclulabs.com (surface B) and drives the
# participant claim for each, linking ghost participants to their noCluID. It ships
# inert: with VERIFY_SYNC_ENABLED false the scheduler starts no timers and touches
# neither the database nor the network. Set it true only after NOCLULABS_BASE_URL
# and NOCLULABS_SERVICE_TOKEN are set (config load fails fast otherwise) and the
# Discord OAuth app exists. Accepts only "true" or "false".
VERIFY_SYNC_ENABLED=false
# The fast-path incremental poll cadence, in milliseconds.
VERIFY_SYNC_INTERVAL_MS=60000
# The full re-scan cadence, in milliseconds (the gap-closure sweep, slower than the
# fast path). The re-scan closes the commit-order gap surface B's cursor cannot.
VERIFY_SYNC_RESCAN_INTERVAL_MS=3600000
# The page size requested from surface B (1 to 500; the server clamps to its max).
VERIFY_SYNC_PAGE_SIZE=200

# Emit client (the outbound bridge emit capability). When a claimed participant's
# network level changes, noCluNetwork pushes their capped leveling contribution up
# to noclulabs.com's signal intake (surface A). It ships inert: with
# EMIT_SYNC_ENABLED false no triggering event emits and nothing touches the network.
# Set it true only after NOCLULABS_BASE_URL and NOCLULABS_SERVICE_TOKEN are set
# (config load fails fast otherwise); it reuses those and NOCLULABS_HTTP_TIMEOUT_MS
# from the poller above. Accepts only "true" or "false".
EMIT_SYNC_ENABLED=false
